# Environment variables for AWS App Runner deployment
# Set these before running: .\scripts\deploy-apprunner.ps1 -FirstTime
# Or configure them in the App Runner service in AWS Console

# Required: JWT secret for access tokens (use a strong random value in production)
JWT_SECRET_KEY=your-secret-key-change-in-production

# Required for production: PostgreSQL connection string
# For RDS: postgresql://user:password@your-db.region.rds.amazonaws.com:5432/insight_gym_usa
# App Runner needs VPC connector to reach RDS in a private subnet
DATABASE_URL=postgresql://user:password@localhost:5432/insight_gym_usa
